@page
@model MedicalClinic.Pages.Patients.ReviewsModel
@{
    ViewData["Title"] = "Recenzii";
}

<h2>Recenzii Doctori</h2>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

<h4>Consultații Finalizate — Adaugă Recenzie</h4>
@if (Model.CompletedAppointments.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Data</th>
                <th>Doctor</th>
                <th>Tip Consultație</th>
                <th>Recenzie</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.CompletedAppointments)
            {
                <tr>
                    <td>@a.StartTime.ToString("dd/MM/yyyy")</td>
                    <td>@a.Doctor.Name</td>
                    <td>@a.ConsultationType.Name</td>
                    <td>
                        @if (Model.ReviewedAppointmentIds.Contains(a.AppointmentId))
                        {
                            <span class="badge bg-success">Recenzie adăugată</span>
                        }
                        else
                        {
                            <form method="post">
                                <input type="hidden" name="DoctorId" value="@a.DoctorId" />
                                <div class="d-flex align-items-center gap-2">
                                    <select name="Score" class="form-select form-select-sm w-auto">
                                        <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                                        <option value="4">⭐⭐⭐⭐ (4)</option>
                                        <option value="3">⭐⭐⭐ (3)</option>
                                        <option value="2">⭐⭐ (2)</option>
                                        <option value="1">⭐ (1)</option>
                                    </select>
                                    <input type="text" name="Comment" class="form-control form-control-sm"
                                           placeholder="Comentariu (opțional)" />
                                    <div class="form-check">
                                        <input type="checkbox" name="IsAnonymous" value="true"
                                               class="form-check-input" id="anon_@a.AppointmentId" />
                                        <label class="form-check-label" for="anon_@a.AppointmentId">Anonim</label>
                                    </div>
                                    <button type="submit" class="btn btn-sm btn-primary">Trimite</button>
                                </div>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Nu ai consultații finalizate încă.</p>
}

<h4 class="mt-4">Recenziile Mele</h4>
@if (Model.MyReviews.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Doctor</th>
                <th>Rating</th>
                <th>Comentariu</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.MyReviews)
            {
                <tr>
                    <td>@r.Doctor.Name</td>
                    <td>@string.Concat(Enumerable.Repeat("⭐", r.Score))</td>
                    <td>@(r.IsAnonymous ? "Anonim" : r.Comment)</td>
                    <td>
                        <span class="badge @(r.IsApproved ? "bg-success" : "bg-warning text-dark")">
                            @(r.IsApproved ? "Aprobat" : "În așteptare")
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Nu ai adăugat recenzii încă.</p>
}

<a href="/Patients/Dashboard" class="btn btn-secondary mt-3">Înapoi</a>