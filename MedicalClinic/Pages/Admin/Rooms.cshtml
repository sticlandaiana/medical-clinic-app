@page
@model MedicalClinic.Pages.Admin.RoomsModel
@{
    ViewData["Title"] = "Săli";
}

<h2>Săli Medicale</h2>

<form method="post">
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <input asp-for="NewRoomName" class="form-control" placeholder="Nume sală" />
            <span asp-validation-for="NewRoomName" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <select asp-for="NewRoomSpecialityId" class="form-select"
                    asp-items="@(new SelectList(Model.Specialities, "SpecialityId", "Name"))">
                <option value="">-- Fără restricție de specialitate --</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Adaugă</button>
        </div>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nume</th>
            <th>Specialitate</th>
            <th>Status</th>
            <th>Acțiuni</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model.Rooms)
        {
            <tr>
                <td>@r.Name</td>
                <td>@(r.Speciality?.Name ?? "Orice specialitate")</td>
                <td>
                    <span class="badge @(r.Status == "Available" ? "bg-success" : "bg-danger")">
                        @r.Status
                    </span>
                </td>
                <td>
                    <form method="post" asp-page-handler="ToggleStatus" style="display:inline">
                        <input type="hidden" name="id" value="@r.RoomId" />
                        <button type="submit" class="btn btn-sm btn-warning">
                            @(r.Status == "Available" ? "Dezactivează" : "Activează")
                        </button>
                    </form>
                    <form method="post" asp-page-handler="Delete" style="display:inline">
                        <input type="hidden" name="id" value="@r.RoomId" />
                        <button type="submit" class="btn btn-sm btn-danger">Șterge</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
